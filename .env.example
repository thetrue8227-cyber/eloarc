# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PAWN=price_...
STRIPE_PRICE_KNIGHT=price_...
STRIPE_PRICE_KING=price_...

# Database
DATABASE_URL=postgresql://user:password@host:5432/eloarc

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this

# Email (Gmail example — use App Password)
# If EMAIL_USER/EMAIL_PASS are not set, password-reset links are logged
# to the server console as a fallback for local dev.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-google-app-password

# URLs
CLIENT_URL=http://localhost:5173
NODE_ENV=development
PORT=4000
